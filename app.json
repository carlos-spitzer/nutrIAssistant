{
  "expo": {
    "name": "nutrIAssistant",
    "slug": "nutrIAssistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutriassistant",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "minimumOsVersion": "18.1",
      "bundleIdentifier": "com.anonymous.nutrIAssistant",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "NutrIAssistant uses speech recognition so you can ask the AI assistant questions by voice.",
        "NSMicrophoneUsageDescription": "NutrIAssistant uses the microphone to capture your voice commands for the AI assistant."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF5",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.nutrIAssistant"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F1EFE8",
          "dark": {
            "backgroundColor": "#2C2C2A"
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "NutrIAssistant needs camera access to scan food barcodes and photograph ingredients.",
          "microphonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NutrIAssistant needs photo library access to select food images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
